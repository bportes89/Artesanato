generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String
  mentorshipPaidAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  payments             Payment[]
  passwordResetTokens  PasswordResetToken[]
}

model Lead {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model CurationItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  tag         String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VideoLesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String
  durationSec Int?
  sortOrder   Int      @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id                    String   @id @default(cuid())
  userId                String
  provider              String
  providerSessionId     String   @unique
  providerPaymentIntent String?
  status                String
  amountCents           Int
  currency              String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
